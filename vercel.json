{
  "buildCommand": "cd quiz-exam-frontend && npm install && npx vite build",
  "outputDirectory": "quiz-exam-frontend/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://quiz-and-examination-system-production.up.railway.app/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
